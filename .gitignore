# ──────────────────────────────────────────────────────────────────────────────
#  Environment & Secrets  ← CRITICAL: DO NOT COMMIT REAL SECRETS
# ──────────────────────────────────────────────────────────────────────────────

# All .env files (development, production, staging, local overrides)
# NOTE: .env.example files ARE tracked — they are templates, not secrets
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*

# Streamlit app secrets & config (created locally)
.streamlit/
.streamlit/secrets.toml
.streamlit/config.toml

# SSH keys, certificates, local PEM files
*.pem

