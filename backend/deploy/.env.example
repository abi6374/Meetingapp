# ── REQUIRED ────────────────────────────────────────────
# Generate a strong random key for JWT signing
# Run: openssl rand -hex 32
SECRET_KEY=change_me_to_a_random_hex_string

# ── AI PROVIDERS (at least one is needed for MoM & Chat) ──
# Groq (free tier available): https://console.groq.com/keys
GROQ_API_KEY=
# Gemini (free tier available): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Hugging Face token (needed for speaker diarization): https://huggingface.co/settings/tokens
HF_TOKEN=

# ── OPTIONAL ─────────────────────────────────────────────
# For a self-hosted Ollama instance
OLLAMA_URL=http://localhost:11434
# Whisper model size: tiny | base | small (tiny = 150MB RAM, base = 600MB)
WHISPER_MODEL=tiny
